# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Deepgram Voice Agent (replaces OpenAI Realtime)
# Get your API key at: https://console.deepgram.com
# Keys look like: abc123def456... (long string, NOT a git commit hash)
DEEPGRAM_API_KEY=your-deepgram-api-key

# ─────────────────────────────────────────────────────────────────────────────
# LLM Configuration for Deepgram Voice Agent
# ─────────────────────────────────────────────────────────────────────────────
# Supported provider types:
#   open_ai       → OpenAI (gpt-4o, gpt-4o-mini, etc.) — requires OPENAI_API_KEY
#   deepseek      → DeepSeek (deepseek-chat, deepseek-reasoner) — requires DEEPSEEK_API_KEY
#   custom        → Any OpenAI-compatible API (Ollama, vLLM, LM Studio, etc.)
#
# For custom/self-hosted LLMs, set LLM_ENDPOINT_URL to your API base URL.
# The endpoint must implement the OpenAI Chat Completions API format.
# ─────────────────────────────────────────────────────────────────────────────
DEEPGRAM_LLM_PROVIDER_TYPE=deepseek
DEEPGRAM_LLM_MODEL=deepseek-chat

# Custom LLM endpoint (only used when DEEPGRAM_LLM_PROVIDER_TYPE=custom)
# Examples:
#   DeepSeek:   https://api.deepseek.com/v1
#   Ollama:     http://localhost:11434/v1
#   vLLM:       http://localhost:8000/v1
#   LM Studio:  http://localhost:1234/v1
DEEPGRAM_LLM_ENDPOINT_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=your-deepseek-api-key

# API keys (set the one matching your provider type)
OPENAI_API_KEY=

# ElevenLabs TTS Configuration
# Get your API key at: https://elevenlabs.io/docs/api-reference/authentication
# Voice IDs: https://elevenlabs.io/docs/api-reference/voices/search
# Models: eleven_multilingual_v2 (29 langs incl. Arabic), eleven_turbo_v2_5 (32 langs, lower latency)
ELEVEN_LABS_API_KEY=your-elevenlabs-api-key
NEXT_PUBLIC_ELEVEN_LABS_API_KEY=your-elevenlabs-api-key
ELEVEN_LABS_VOICE_ID=your-elevenlabs-voice-id
NEXT_PUBLIC_ELEVEN_LABS_VOICE_ID=your-elevenlabs-voice-id
ELEVEN_LABS_MODEL=eleven_multilingual_v2
NEXT_PUBLIC_ELEVEN_LABS_MODEL=eleven_multilingual_v2


# Application URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OPTIONAL: Business ID for the live demo widget on the landing page
# Leave empty to hide the widget entirely. Fill in when you want to enable it.
NEXT_PUBLIC_DEMO_BUSINESS_ID=

# Deepgram Voice Agent Configuration
# Region: us (default), eu (recommended for MENA/Europe), au (Australia/Asia-Pacific)
# EU endpoint: wss://api.eu.deepgram.com/v1/agent/converse (lower latency for MENA)
NEXT_PUBLIC_DEEPGRAM_REGION=eu
NEXT_PUBLIC_DEEPGRAM_STT_MODEL=flux-general-en
NEXT_PUBLIC_DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# LLM config exposed to client (for Deepgram Settings message)
NEXT_PUBLIC_DEEPGRAM_LLM_PROVIDER_TYPE=deepseek
NEXT_PUBLIC_DEEPGRAM_LLM_MODEL=deepseek-chat

# Voice Feature Toggle
NEXT_PUBLIC_ENABLE_VOICE=true

# ─────────────────────────────────────────────────────────────────────────────
# Marsa Tijarah Marketplace API (External Supabase instance)
# Used by the Marsa Tijarah voice agent for product/category/seller lookups
# Base URL: https://your-marsatijarah-project.supabase.co/rest/v1
# ─────────────────────────────────────────────────────────────────────────────
MARSATIJARAH_SUPABASE_URL=https://your-marsatijarah-project.supabase.co
MARSATIJARAH_SUPABASE_ANON_KEY=your-marsatijarah-supabase-anon-key
